{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BiliBox",
  "version": "0.1.0",
  "identifier": "com.bilibili.box",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "BiliBox",
        "width": 1120,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "center": true,
        "useHttpsScheme": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: data: blob:; media-src 'self' asset: https: data: blob: bili-media: https://bili-media.localhost; font-src 'self' data:; connect-src 'self' https: wss: ws: ipc: bili-media: https://bili-media.localhost;"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
